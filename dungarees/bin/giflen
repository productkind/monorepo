#!/usr/bin/env zsh
# Change GIF playback length by a ratio (>1 slows/lengthens, <1 speeds up). Depends on: ffmpeg.

giflen() {
    local -A opts
    zparseopts -E -D -A opts r:
    [[ -z "$1" ]] && echo "Usage: giflen <file> [out] [-r ratio]  (ratio >1 slows/lengthens, <1 speeds up; out defaults to in-place)" && return 1

    local input="$1"
    local output="${2:-$1}"
    [[ -d "$output" ]] && output="${output%/}/$(basename "$1")"

    local ratio="${opts[-r]:-1.15}"

    # ffmpeg can't read and write the same file, so use a temp when overwriting in place
    local final_output="$output"
    local tmp_out=""
    if [[ "$output" == "$input" ]]; then
        tmp_out=$(mktemp -t giflen.XXXXXX.gif)
        trap "rm -f '$tmp_out'" EXIT INT TERM
        output="$tmp_out"
    fi

    echo "⏱️  GIF length x${ratio}..."
    ffmpeg -v warning -i "$input" \
        -filter_complex "[0:v]setpts=${ratio}*PTS,split[s0][s1];[s0]palettegen[p];[s1][p]paletteuse" \
        -y "$output"

    if [[ $? -eq 0 ]]; then
        [[ -n "$tmp_out" ]] && mv -f "$tmp_out" "$final_output"
        echo "✅ Done: $final_output ($(du -h "$final_output" | cut -f1))"
    fi
}

giflen "$@"
